# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Supabase: Settings → Database → Connection string (URI).
DATABASE_URL=postgres://user:password@localhost:5432/deanos

# Supabase keys are only needed if/when Supabase auth, storage or realtime are
# adopted in later phases. The Phase 1 app talks to Postgres directly.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Model per prompt, so each can be tuned/upgraded independently.
OPENAI_MODEL_MEETING_PROCESSOR=gpt-4.1
# Reserved for later phases:
# OPENAI_MODEL_EMAIL_PROCESSOR=
# OPENAI_MODEL_PRIORITIZER=

# ─── Zapier ──────────────────────────────────────────────────────────────────
# Shared secret sent by every Zapier → DeanOS webhook request in the
# X-DeanOS-Secret header. Generate with: openssl rand -hex 32
ZAPIER_WEBHOOK_SECRET=

# ─── Todoist ─────────────────────────────────────────────────────────────────
# Preferred: direct Todoist API (no Zapier tasks consumed). Get the token at
# Todoist → Settings → Integrations → Developer → API token.
TODOIST_API_TOKEN=

# Fallback: Zapier Catch Hook URLs used only when TODOIST_API_TOKEN is unset.
ZAPIER_TODOIST_CREATE_HOOK_URL=
ZAPIER_TODOIST_UPDATE_HOOK_URL=
ZAPIER_TODOIST_COMPLETE_HOOK_URL=

# ─── App ─────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
# Generate with: openssl rand -base64 48
SESSION_SECRET=

# ─── Single-user login ───────────────────────────────────────────────────────
DEANOS_EMAIL=deano@heya.team
# Generate with: npm run hash-password -- 'your-password-here'
DEANOS_PASSWORD_HASH=
