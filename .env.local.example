# ─── Microsoft / Azure AD ────────────────────────────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI: http://localhost:3000/api/auth/callback/azure-ad (or your production URL)
# API Permissions: Calendars.Read, Calendars.Read.Shared, Mail.Read, User.Read, offline_access

AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_TENANT_ID=your-tenant-id

# ─── CEO Calendar ────────────────────────────────────────────────────────────
# Yehuda must share their calendar with you in Outlook first, OR
# your admin can grant delegate/impersonation access via Exchange.
CEO_EMAIL=yehuda@yourcompany.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with: openssl rand -base64 32

# CEO display name shown in the header
NEXT_PUBLIC_CEO_NAME=Yehuda
