# ─── Microsoft / Azure AD ────────────────────────────────────────────────────
# Register an app at https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI: http://localhost:3000/api/auth/callback/azure-ad (or your production URL)
# Delegated permissions: Calendars.Read, Calendars.Read.Shared, Mail.Read, User.Read, offline_access
# Application permissions (for cron job): Mail.ReadWrite, Mail.Send

AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
AZURE_AD_TENANT_ID=your-tenant-id

# ─── CEO Calendar ────────────────────────────────────────────────────────────
# Yehuda must share their calendar with you in Outlook first, OR
# your admin can grant delegate/impersonation access via Exchange.
CEO_EMAIL=yehuda@yourcompany.com

# ─── App ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with: openssl rand -base64 32

# CEO display name shown in the header
NEXT_PUBLIC_CEO_NAME=Yehuda

# ─── Daily Email Digest (cron job) ───────────────────────────────────────────
# The mailbox to search and send the digest from/to
MAILBOX_USER_EMAIL=you@yourdomain.com

# Subject keyword to match (default: Daily Summary Report)
EMAIL_SUBJECT_KEYWORD=Daily Summary Report

# Inbox subfolder emails are filed into (default: Daily Digest)
EMAIL_DIGEST_FOLDER=Daily Digest

# Timezone for date/time formatting in the digest email (default: Australia/Sydney)
DIGEST_TIMEZONE=Australia/Sydney

# Secret used to authorise the cron endpoint — generate with: openssl rand -hex 32
# Set this same value in Vercel → Settings → Environment Variables → CRON_SECRET
CRON_SECRET=generate-with: openssl rand -hex 32
